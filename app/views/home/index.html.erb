<% if logged_in? %>
  <h1>Legal Advice Board</h1>

  <p>Welcome, <%= current_user.name %>.</p>

  <%= link_to "View Questions", questions_path %>

  <% if @permissions.create_questions? %>
    <%= link_to "Ask a Question", new_question_path %>
  <% end %>

<% else %>

  <h1>Legal Advice Board</h1>

  <%= form_with url: login_path do |form| %>
    <div>
      <%= form.label :email_address %>
      <%= form.email_field :email_address %>
    </div>

    <div>
      <%= form.label :password %>
      <%= form.password_field :password %>
    </div>

    <%= form.submit "Sign in" %>
  <% end %>

<% end %>
