<h1>Sign in</h1>

<%= form_with url: login_path do |form| %>
  <div>
    <%= form.label :email_address %>
    <%= form.email_field :email_address, autofocus: true %>
  </div>

  <div>
    <%= form.label :password %>
    <%= form.password_field :password %>
  </div>

  <%= form.submit "Sign in" %>
<% end %>