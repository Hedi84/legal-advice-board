<h1>Ask a question</h1>

<%= link_to "Back to questions", questions_path %>

<% if @question.errors.any? %>
  <div>
    <h2>Please fix the following:</h2>

    <ul>
      <% @question.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @question do |form| %>
  <div>
    <%= form.label :title %>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :category %>
    <%= form.select :category, Question::CATEGORIES, prompt: "Select a category" %>
  </div>

  <div>
    <%= form.label :body %>
    <%= form.text_area :body, rows: 8 %>
  </div>

  <%= form.submit "Submit question" %>
<% end %>