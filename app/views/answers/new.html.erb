<div class="container">
  <%= link_to "← Back to question", question_path(@question), class: "back-link" %>

  <div class="question-card question-card--<%= @question.status %>">
    <div class="question-card__header">
      <span class="question-card__category"><%= @question.category %></span>
      <span class="status-badge status-badge--<%= @question.status %>"><%= @question.status.humanize %></span>
    </div>
    <h2 class="question-card__title"><%= @question.title %></h2>
    <p class="question-card__body"><%= @question.body %></p>
    <div class="question-card__footer">
      <span>Asked by <%= @question.user.name %></span>
      <span><%= time_ago_in_words(@question.created_at) %> ago</span>
    </div>
  </div>

  <div class="form-card">
    <h2 class="form-card__title">Your Answer</h2>

    <% if @answer.errors.any? %>
      <div class="flash flash--alert" style="margin: 0 0 1.25rem;">
        <span><%= @answer.errors.full_messages.to_sentence %></span>
      </div>
    <% end %>

    <%= form_with model: [@question, @answer] do |form| %>
      <div class="form-group">
        <%= form.label :response, "Response" %>
        <%= form.text_area :response, rows: 8, class: "form-control" %>
      </div>

      <div class="form-group">
        <%= form.label :fee_pounds, "Proposed fee (£)" %>
        <%= form.number_field :fee_pounds, min: 1, class: "form-control" %>
      </div>

      <%= form.submit "Submit Answer", class: "btn btn--primary" %>
    <% end %>
  </div>
</div>
