<div class="form-card form-card--page-wide">
  <%= link_to "← Back to questions", questions_path, class: "back-link" %>
  <h1 class="form-card__title">Ask a question</h1>

  <% if @question.errors.any? %>
    <div class="flash flash--alert" style="margin: 0 0 1.25rem;">
      <span><%= @question.errors.full_messages.to_sentence %></span>
    </div>
  <% end %>

  <%= form_with model: @question do |form| %>
    <div class="form-group">
      <%= form.label :title %>
      <%= form.text_field :title, class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :category %>
      <%= form.select :category, Question::CATEGORIES,
                      { prompt: "Select a category" },
                      class: "form-control" %>
    </div>

    <div class="form-group">
      <%= form.label :body, "Details" %>
      <%= form.text_area :body, rows: 8, class: "form-control" %>
    </div>

    <%= form.submit "Submit question", class: "btn btn--primary btn--full" %>
  <% end %>
</div>
